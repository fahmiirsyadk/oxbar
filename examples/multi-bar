# oxbar configuration

bar left {
    position top
    alignment left
    height 24
    font monospace:size=11
    fg #ffffff
    bg #000000
    sep_color #555555
    padding 8

    widget time {
        interval 1
    }

    widget sep {}

    widget cpu {
        icon CPU
        interval 1
    }

    widget sep {}

    widget mem {
        icon MEM
        interval 1
    }
}

bar center {
    position top
    alignment center
    height 24
    font monospace:size=11
    fg #ffffff
    bg #000000
    sep_color #555555
    padding 8

    widget date {
        interval 60
    }
}

bar right {
    position top
    alignment right
    height 24
    font monospace:size=11
    fg #ffffff
    bg #000000
    sep_color #555555
    padding 8

    widget vol {
        icon VOL
        interval 1
        click cmd "pavucontrol"
    }

    widget sep {}

    widget bright {
        icon LIT
        interval 5
    }

    widget sep {}

    widget bat {
        icon BAT
        interval 30
    }
}
